    "faq": {
      "title": "FAQ",
      "subtitle": "Questions fréquentes",
      "all": "Tout",
      "helpText": "Vous ne trouvez pas la réponse à votre question ?",
      "consultPrefix": "Consultez les",
      "communityResources": "ressources communautaires",
