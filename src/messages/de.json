      "question": "Frage",
      "questions": "Fragen",
      "items": {
        "app-data-privacy": {
          "q": "Sind meine Daten sicher?",
          "a": "Ja, alle deine Daten werden ausschließlich auf deinem Gerät gespeichert (IndexedDB). Nichts wird an einen Server gesendet. Du hast die volle Kontrolle über deine persönlichen Informationen. Denk daran, regelmäßig Sicherungen über die Export-Funktion in den Einstellungen zu machen."
        },
        "app-offline": {
          "q": "Funktioniert die App offline?",
          "a": "Ja! Chrysalide ist eine PWA (Progressive Web App) und funktioniert nach der Installation vollständig offline. Alle Funktionen sind ohne Internetverbindung verfügbar."
        },
        "app-backup": {
          "q": "Wie sichere ich meine Daten?",
          "a": "Gehe zu Einstellungen > Daten exportieren. Eine JSON-Datei mit all deinen Daten wird heruntergeladen. Bewahre sie an einem sicheren Ort auf. Zum Wiederherstellen nutze die Import-Funktion in den Einstellungen."
        },
        "app-install": {
          "q": "Wie installiere ich die App auf meinem Handy?",
          "a": "Auf Android (Chrome): Menü ⋮ > \"App installieren\" oder \"Zum Startbildschirm hinzufügen\". Auf iOS (Safari): Teilen-Button > \"Zum Home-Bildschirm\". Die App ist dann wie eine native App verfügbar."
        },
        "app-notifications": {
          "q": "Wie aktiviere ich Medikamenten-Erinnerungen?",
          "a": "Gehe zu Einstellungen > Benachrichtigungen und aktiviere die Erinnerungen. Stelle sicher, dass du Benachrichtigungen in deinem Browser erlaubst. Die Erinnerungen funktionieren auch, wenn die App geschlossen ist (bei Installation als PWA)."
        },
        "app-delete-data": {
          "q": "Wie lösche ich alle meine Daten?",
          "a": "Gehe zu Einstellungen > Alle Daten löschen. Diese Aktion ist unumkehrbar. Denke daran, deine Daten vorher zu exportieren, falls du sie behalten möchtest."
        },
        "med-ranges": {
          "q": "Was bedeuten die Referenzbereiche in den Diagrammen?",
          "a": "Die farbigen Bereiche in den Testdiagrammen stellen die Zielbereiche einer HRT dar. Werte im grünen Bereich sind meist optimal. Diese Bereiche sind Richtwerte – nur dein·e Ärzt·in kann deine Ergebnisse im persönlichen Kontext interpretieren."
        },
        "med-tracking": {
          "q": "Warum soll ich meine Medikamenteneinnahmen verfolgen?",
          "a": "Das Tracking hilft dir: 1) Keine Einnahmen zu vergessen, 2) Einen genauen Verlauf für deine Arzttermine zu haben, 3) Muster zu erkennen (wiederkehrende Vergessungen, Nebenwirkungen), 4) Deinen Bestand zu verwalten und Nachbestellungen zu planen."
        },
        "med-not-advice": {
          "q": "Ersetzt diese App eine medizinische Betreuung?",
          "a": "Nein, absolut nicht. Chrysalide ist ein persönliches Tracking-Tool, kein medizinischer Rat. Wende dich bei medizinischen Entscheidungen immer an medizinisches Fachpersonal. Die App hilft dir, deine Informationen für deine Termine zu organisieren."
        },
        "gen-name": {
          "q": "Warum der Name \"Chrysalide\"?",
          "a": "Die Chrysalide ist der Kokon, in dem sich die Raupe in einen Schmetterling verwandelt. Das ist eine Metapher für die Transition: ein geschützter Raum persönlicher Verwandlung. Der Schmetterling, der daraus hervorgeht, steht für das Aufblühen."
        },
        "gen-contribute": {
          "q": "Wie kann ich zum Projekt beitragen?",
          "a": "Chrysalide ist ein Open-Source-Projekt. Du kannst über GitHub beitragen: Bugs melden, Funktionen vorschlagen, Code oder Dokumentation verbessern. Jedes Feedback ist wertvoll!"
        },
        "gen-support": {
          "q": "Ich brauche dringend Hilfe, was kann ich tun?",
          "a": "Wenn du in Not bist, wende dich an eine Telefonseelsorge (siehe Ressourcen > Unterstützung). Im medizinischen Notfall wähle 112. Du bist nicht allein."
        }
      }
    }
  },
