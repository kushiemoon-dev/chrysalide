      "items": {
        "app-data-privacy": {
          "q": "Is my data secure?",
          "a": "Yes, all your data is stored only on your device (IndexedDB). Nothing is sent to any server. You have full control over your personal information. Remember to make regular backups via the Export function in settings."
        },
        "app-offline": {
          "q": "Does the app work offline?",
          "a": "Yes! Chrysalide is a PWA (Progressive Web App) that works entirely offline once installed. All features are available without an internet connection."
        },
        "app-backup": {
          "q": "How do I back up my data?",
          "a": "Go to Settings > Export data. A JSON file containing all your data will be downloaded. Keep it in a safe place. To restore, use the Import function in settings."
        },
        "app-install": {
          "q": "How do I install the app on my phone?",
          "a": "On Android (Chrome): Menu ⋮ > \"Install app\" or \"Add to home screen\". On iOS (Safari): Share button > \"Add to Home Screen\". The app will be available like a native application."
        },
        "app-notifications": {
          "q": "How do I enable medication reminders?",
          "a": "Go to Settings > Notifications and enable reminders. Make sure to allow notifications in your browser. Reminders work even when the app is closed (if installed as a PWA)."
        },
        "app-delete-data": {
          "q": "How do I delete all my data?",
          "a": "Go to Settings > Delete all data. This action is irreversible. Consider exporting your data first if you want to keep it."
        },
        "med-ranges": {
          "q": "What do the reference ranges on the charts mean?",
          "a": "The colored zones on the test charts represent target ranges for HRT. Values in the green zone are generally optimal. These ranges are indicative — only your doctor can interpret your results in your personal context."
        },
        "med-tracking": {
          "q": "Why track my medication doses?",
          "a": "Tracking helps you: 1) not miss doses, 2) have an accurate history for your medical appointments, 3) identify patterns (recurring missed doses, side effects), 4) manage your stock and anticipate refills."
        },
        "med-not-advice": {
          "q": "Does this app replace medical care?",
          "a": "No, absolutely not. Chrysalide is a personal tracking tool, not medical advice. Always consult a healthcare professional for your medical decisions. The app helps you organize your information for appointments."
        },
        "gen-name": {
          "q": "Why the name \"Chrysalide\"?",
          "a": "The chrysalis is the cocoon in which a caterpillar transforms into a butterfly. It's a metaphor for transition: a protected space for personal transformation. The butterfly that emerges symbolizes flourishing."
        },
        "gen-contribute": {
          "q": "How can I contribute to the project?",
          "a": "Chrysalide is an open source project. You can contribute via GitHub: report bugs, suggest features, improve the code or documentation. All feedback is valuable!"
        },
        "gen-support": {
          "q": "I need urgent help, what should I do?",
          "a": "If you're in distress, contact a helpline (see Resources > Support). In case of a medical emergency, call your local emergency number (911 in the US, 112 in Europe). You are not alone."
        }
      }
    }
